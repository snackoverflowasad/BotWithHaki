{
  "name": "chat-buddy",
  "version": "1.6.0",
  "description": "WhatsApp AI Bot — Automate, Reply, Schedule, Assist. Powered by OpenAI Agents SDK.",
  "keywords": [
    "whatsapp",
    "bot",
    "ai",
    "openai",
    "agents",
    "automation",
    "cli",
    "assistant"
  ],
  "homepage": "https://github.com/snackoverflowasad/BotWithHaki#readme",
  "bugs": {
    "url": "https://github.com/snackoverflowasad/BotWithHaki"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snackoverflowasad/BotWithHaki.git"
  },
  "license": "MIT",
  "author": "Asad Hussain",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "chat-buddy": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "credentials.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npx tsc",
    "dev": "npx tsc && node dist/cli/index.js run",
    "start": "node dist/cli/index.js run",
    "init": "node dist/cli/index.js init",
    "log": "node dist/cli/index.js login",
    "login": "node dist/cli/index.js login",
    "reset": "node dist/cli/resetHandler.js reset",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@openai/agents": "^0.4.6",
    "@openai/agents-openai": "^0.8.5",
    "commander": "^13.1.0",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "hono": "^4.12.19",
    "openai": "^6.35.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
